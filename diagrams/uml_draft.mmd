classDiagram
    class Owner {
        +String name
        +List~Pet~ pets
        +add_pet()
        +list_pets()
        +get_all_tasks()
    }
    class Pet {
        +String name
        +String species
        +List~Task~ tasks
        +add_task()
        +list_tasks()
    }
    class Task {
        +String description
        +Date due_date
        +Time due_time
        +bool completed
        +String frequency
        +String priority
        +mark_complete()
        +is_recurring()
    }
    class Scheduler {
        +Owner owner
        +get_all_tasks()
        +sort_tasks_by_time()
        +filter_tasks_by_status()
        +filter_tasks_by_pet()
        +detect_conflicts()
    }

    Owner "1" o-- "*" Pet : owns
    Pet "1" o-- "*" Task : contains
